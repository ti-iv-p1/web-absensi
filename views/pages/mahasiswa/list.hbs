<div class="d-flex justify-content-between mb-3">
    <h1>List Mahasiswa</h1>
    
    <a href="/mahasiswa/create" class="btn btn-success mb-3">Tambah Mahasiswa</a>
</div>

<table class="table table-bordered">
    <thead>
        <th>NIM</th>
        <th>Nama</th>
        <th>Email</th>
        <th>Program Studi</th>
        <th>Angkatan</th>
        <th colspan="2">Actions</th>
    </thead>
    <tbody>
        {{#unless mahasiswa.length }}
        <tr>
            <td colspan="7" class="text-center">
                Tidak ada mahasiswa yang ditemukan <br>
                <a href="/mahasiswa/create" class="link">Tambah Mahasiswa</a>
            </td>
        </tr>
        {{/unless }}

        {{#each mahasiswa}}
        <tr>
            <td>{{nim}}</td>
            <td>{{nama}}</td>
            <td>{{email}}</td>
            <td>{{program_studi}}</td>
            <td>{{angkatan}}</td>
            <td>
                <a href="/mahasiswa/edit/{{id}}" class="btn btn-warning w-100">Edit</a>
            </td>
            <td>
                <form action="/mahasiswa/delete/{{id}}" method="POST"
                    onsubmit="return confirm('Are you sure you want to delete this mahasiswa?');">
                    <button type="submit" class="btn btn-danger w-100">Delete</button>
                </form>
            </td>
        </tr>
        {{/each}}
    </tbody>
    <tfoot>
        <tr>
            <td colspan="7" class="text-center">Total Mahasiswa: {{mahasiswa.length}}</td>
        </tr>
    </tfoot>
</table>